# Copy this file to .env on the NanoPi and fill in the secret values.
# Do not commit .env.

# Timezone used by UpSnap schedules and container logs.
TZ=America/Chicago

# UPS identity. These values came from the working Nutify wizard output.
# Short NUT name for this UPS. Clients use this as `<name>@<host>`.
UPS_NAME=lab_apc
# NUT driver for the UPS.
UPS_DRIVER=usbhid-ups
# Usually `auto` for USB UPS devices.
UPS_PORT=auto
# USB vendor ID used to identify the UPS.
UPS_VENDOR_ID=051D
# USB product ID used to identify the UPS.
UPS_PRODUCT_ID=0002
# Human-readable USB product string.
UPS_PRODUCT_STRING=Back-UPS RS 1500MS2 FW:969.e4 .D USB FW:e4
# UPS serial number.
UPS_SERIAL=0B2530L07045
# UPS vendor name shown in Nutify.
UPS_VENDOR_NAME=American Power Conversion

# Optional Nutify profile fields.
# Nutify display/profile value.
UPS_INPUT_SENSITIVITY=medium
# Nutify display/profile value.
UPS_DEVICE_MODEL=Back-UPS RS 1500MS2
# Nutify display/profile value.
UPS_BATTERY_TYPE=PbAc
# Battery replacement/install date, if you want Nutify to track it.
UPS_BATTERY_DATE=
# Battery manufacture date, if known.
UPS_BATTERY_MFR_DATE=

# NUT users. All NUT clients should use NUT_MON_USER/NUT_MON_PASSWORD.
# Username NUT clients use for monitoring.
NUT_MON_USER=monuser
# Password NUT clients use for monitoring.
NUT_MON_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Local primary upsmon user inside Nutify. Do not use this on remote clients.
NUT_PRIMARY_USER=primarymon
# Local primary upsmon password inside Nutify.
NUT_PRIMARY_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Admin user written into the NUT config.
NUT_ADMIN_USER=admin
# Admin password written into the NUT config.
NUT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Nutify web/database bootstrap.
# Name Nutify should give the local server entry.
NUTIFY_SERVER_NAME=nutify
# Host port for the Nutify web UI.
NUTIFY_WEB_PORT=5050
# Flask secret key for Nutify sessions. Use a long random value.
# Use a long random string; 32+ characters is a good minimum.
NUTIFY_SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING
# Initial Nutify admin username.
NUTIFY_ADMIN_USER=admin
# Initial Nutify admin password.
NUTIFY_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# File owner UID for generated Nutify config/data.
# Set these to the host user/group that should own files under ./nutify-data.
NUTIFY_CONFIG_UID=1000
# File owner GID for generated Nutify config/data.
# Usually this matches the primary group for NUTIFY_CONFIG_UID.
NUTIFY_CONFIG_GID=1000
# Nutify logging level.
LOG_LEVEL=INFO
# Whether Werkzeug request logs should be enabled.
LOG_WERKZEUG=true
# Whether Nutify should print startup logs.
ENABLE_LOG_STARTUP=Y
# Enable Nutify SSL support if you provide certs.
SSL_ENABLED=false

# Shutdown thresholds.
# FSD is triggered when either battery threshold or time-on-battery threshold is reached.
# Start FSD when battery charge is at or below this percent.
SHUTDOWN_BATTERY_THRESHOLD=20
# Start FSD after this many seconds on battery.
SHUTDOWN_TIME_ON_BATTERY=1800

# Wake threshold after AC restore.
# After a shutdown, wake hosts once AC is back and battery reaches this percent.
WAKEUP_BATTERY_THRESHOLD=60

# UpSnap.
# UpSnap container image to run.
UPSNAP_IMAGE=ghcr.io/seriousm4x/upsnap:5
# Host port for the UpSnap web UI/API.
UPSNAP_PORT=8090
# Optional network range for UpSnap discovery scans.
UPSNAP_SCAN_RANGE=
# Per-host timeout for UpSnap scans.
UPSNAP_SCAN_TIMEOUT=500ms
# Keep true unless you intentionally configure unprivileged ping on the host.
UPSNAP_PING_PRIVILEGED=true
# Title shown in the UpSnap UI.
UPSNAP_WEBSITE_TITLE=UPS Wake

# Create this admin/superuser in the UpSnap UI, then keep the values here for API automation.
# UpSnap admin/superuser email for API calls.
UPSNAP_ADMIN_EMAIL=admin@example.invalid
# UpSnap admin/superuser password for API calls.
UPSNAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# UpSnap SSH shutdown support. Generate a dedicated key, then base64 encode the private key:
# ssh-keygen -t ed25519 -f ./upsnap_shutdown_key -C upsnap-shutdown
# base64 -w0 ./upsnap_shutdown_key
# Base64-encoded private key mounted into the UpSnap container.
# Generate/update with: base64 -w0 ./upsnap_shutdown_key
UPSNAP_SSH_PRIVATE_KEY_B64=
# SSH user UpSnap connects as on target hosts.
UPSNAP_SSH_USER=upsnap-shutdown
# Private key path inside the UpSnap container.
UPSNAP_SSH_KEY_PATH=/app/ssh/id_ed25519
# SSH options used in generated shutdown commands.
UPSNAP_SSH_OPTIONS=-o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/app/ssh/known_hosts
# Remote command run on target hosts when UpSnap shuts them down.
UPSNAP_DEFAULT_SHUTDOWN_COMMAND=sudo /sbin/shutdown -h now
# UpSnap shutdown timeout for provisioned devices.
UPSNAP_DEFAULT_SHUTDOWN_TIMEOUT=120
# How long the provisioner waits for UpSnap to become available.
UPSNAP_INIT_TIMEOUT=120
# Set true to disable UpSnap device provisioning.
UPSNAP_INIT_SKIP=false

# UpSnap device provisioning. Keep this valid JSON on one line for .env parsing.
# Example:
# UPSNAP_HOSTS_JSON=[{"name":"pve1","ip":"192.168.1.10","mac":"aa:bb:cc:dd:ee:ff","netmask":"255.255.255.0","description":"Primary Proxmox host","shutdown_user":"upsnap-shutdown","shutdown_command":"sudo /sbin/shutdown -h now","shutdown_timeout":300,"shutdown_cron":"","shutdown_cron_enabled":false}]
# Available host fields:
# [
#   {
#     "name": "display name in UpSnap",
#     "ip": "host IPv4 address",
#     "mac": "host MAC address for Wake-on-LAN",
#     "netmask": "subnet mask, usually 255.255.255.0",
#     "description": "free-form note shown in UpSnap",
#     "shutdown_user": "SSH user for this host; defaults to UPSNAP_SSH_USER",
#     "shutdown_command": "remote command run over SSH; defaults to UPSNAP_DEFAULT_SHUTDOWN_COMMAND",
#     "shutdown_cmd": "full raw UpSnap command; overrides generated SSH command",
#     "shutdown_timeout": 300,
#     "shutdown_cron": "optional cron schedule, or empty string",
#     "shutdown_cron_enabled": false,
#     "shutdown_confirm": false,
#     "wake_confirm": false,
#     "wake_after_restore": true,
#     "upsnap_id": "optional UpSnap record ID if you want to pin it",
#     "wake_cron": "optional wake cron schedule",
#     "wake_cron_enabled": false,
#     "wake_timeout": 120,
#     "wake_cmd": "optional custom wake command",
#     "ping_cmd": "optional custom ping/status command",
#     "link": "optional URL shown in UpSnap",
#     "link_open": "optional UpSnap link behavior"
#   }
# ]
# Hosts/devices that `upsnap-init` should create or update in UpSnap.
UPSNAP_HOSTS_JSON=[]

# Optional manual wake targets. Usually leave these empty because the watcher can use UPSNAP_HOSTS_JSON.
# Comma-separated UpSnap record IDs to wake after AC is restored; no quotes needed.
UPSNAP_DEVICE_IDS=
# Comma-separated MAC addresses to resolve and wake in addition to UPSNAP_HOSTS_JSON; no quotes needed.
WAKE_MAC_ADDRESSES=

# Watcher tuning.
# How often the watcher asks NUT for UPS status, in seconds.
# 1 second works, but it is usually unnecessary; 10-30 seconds is plenty for UPS shutdown logic.
# Lower values react faster but create more logs and more NUT/API traffic.
POLL_INTERVAL=30
# Safety switch for testing threshold logic.
# true = log that FSD would happen, but do not actually tell NUT to start shutdown.
# false = run the real FSD command when thresholds are reached.
FSD_DRY_RUN=false
# After FSD, the watcher explicitly shuts down the NanoPi host.
# Keep true for production; set false only if you want Nutify/NUT to handle host shutdown by itself.
HOST_SHUTDOWN_ENABLED=true
# Seconds to wait after FSD before shutting down the NanoPi.
# This gives NUT clients time to see FSD and begin their own shutdowns.
HOST_SHUTDOWN_DELAY=120
# Host shutdown command run from inside nut-watcher.
# It uses nsenter to run shutdown in the NanoPi host namespaces. Comma-separated, no quotes.
HOST_SHUTDOWN_COMMAND=nsenter,-t,1,-m,-u,-i,-n,-p,--,/sbin/shutdown,-h,now
# Test-only override. true makes the watcher behave as if the UPS is on battery.
# This is useful for testing thresholds without unplugging AC.
# It is rejected unless FSD_DRY_RUN=true.
FORCE_ON_BATTERY=false
# Test-only override for the reported battery percent.
# Example: FORCE_BATTERY_CHARGE=15 makes the watcher behave as if battery is 15%.
# Leave empty for real UPS data. It is rejected unless FSD_DRY_RUN=true.
FORCE_BATTERY_CHARGE=
