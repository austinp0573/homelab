# Copy this file to .env and edit values for your setup.

TZ=America/Chicago
LOG_LEVEL=INFO

# Stock container images. Pin these once you have a working deployment.
NUTIFY_IMAGE=dartsteven/nutify:latest-raspberrypi5-arm64
UPSNAP_IMAGE=ghcr.io/seriousm4x/upsnap:5

# Nutify web UI port and Flask secret key. Change the secret key.
NUTIFY_WEB_PORT=5050
NUTIFY_SECRET_KEY=4ssamfh2DM9AKYotzLk9bj9gug28N11SIvTB4iIxvYI

# Set this to the UPS name you chose during Nutify's first-run setup.
# nut-policy-init can infer it from ups.conf if blank, but restore-watcher
# and upsc commands need it explicitly, so set it once and leave it.
UPS_NAME=

# Optional NUT variable overrides written into ups.conf by nut-policy-init.
# Leave blank to keep whatever the UPS driver reported.
UPS_BATTERY_DATE=
UPS_BATTERY_MFR_DATE=
UPS_EXTRA_CONFIG=

# Shutdown thresholds. restore-watcher triggers FSD when either condition is met.
# NUT_LOW_BATTERY_THRESHOLD also sets override.battery.charge.low in ups.conf,
# which is what upsd uses to report LOWBATT status.
NUT_LOW_BATTERY_THRESHOLD=50
NUT_ON_BATTERY_SECONDS=1800

# Optional UPS driver timing, written to ups.conf by nut-policy-init.
# NUT_ALLOW_KILLPOWER enables allow_killpower in ups.conf — required for
# driver.killpower to work on most USB HID UPSes.
# offdelay: seconds the UPS waits after receiving killpower before cutting output.
# ondelay: seconds the UPS waits after utility returns before restoring output.
# Leave offdelay/ondelay blank to keep the driver's defaults.
NUT_ALLOW_KILLPOWER=true
NUT_UPS_OFF_DELAY=
NUT_UPS_ON_DELAY=

# NUT client user injected into upsd.users by nut-policy-init.
# Used by restore-watcher for upsc queries and by host nut-monitor clients.
NUT_CLIENT_USER=clientmon
NUT_CLIENT_PASSWORD=changeme
NUT_CLIENT_ROLE=slave

# NUT FSD trigger user injected into upsd.users by nut-policy-init.
# restore-watcher connects directly to upsd and sends "FSD <ups>" using these
# credentials when thresholds are met. Also used for driver.killpower via upscmd.
# Gets actions = FSD and instcmds = driver.killpower in upsd.users.
NUT_FSD_USER=fsdmon
NUT_FSD_PASSWORD=changeme

# UpSnap. The first admin account must be created in the web UI once, then set
# these to match so upsnap-init and restore-watcher can authenticate.
UPSNAP_PORT=8090
UPSNAP_ADMIN_EMAIL=admin@example.com
UPSNAP_ADMIN_PASSWORD=changeme
UPSNAP_WEBSITE_TITLE=Power Control
UPSNAP_INTERVAL=*/10 * * * * *
UPSNAP_SCAN_RANGE=
UPSNAP_SCAN_TIMEOUT=500ms
UPSNAP_PING_PRIVILEGED=true

# SSH key for UpSnap shutdown commands. Generate a key pair, install the public key
# on target hosts via setup-upsnap-shutdown-user.sh, then encode the private key:
#   ssh-keygen -t ed25519 -f ./upsnap_shutdown_key -C "upsnap-shutdown"
#   base64 -w0 ./upsnap_shutdown_key
# Paste the output below. upsnap-ssh-init writes the decoded key before UpSnap starts.
UPSNAP_SSH_PRIVATE_KEY_B64=
UPSNAP_SSH_USER=upsnap-shutdown
UPSNAP_SSH_KEY_PATH=/app/ssh/id_ed25519
UPSNAP_SSH_OPTIONS="-o BatchMode=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/app/ssh/known_hosts"
UPSNAP_DEFAULT_SHUTDOWN_COMMAND="sudo /sbin/shutdown -h now"
SHUTDOWN_COMMAND="/sbin/shutdown -h now"
UPSNAP_DEFAULT_SHUTDOWN_TIMEOUT=120
UPSNAP_INIT_TIMEOUT=120
UPSNAP_INIT_SKIP=false

# Device definitions provisioned into UpSnap by upsnap-init. Must be a single line.
# Per-host fields override the SSH defaults above.
# netmask is the CIDR prefix length UpSnap expects, usually "24" for /24 networks.
UPSNAP_HOSTS_JSON='[{"name":"pve-01","ip":"192.168.1.10","mac":"AA:BB:CC:DD:EE:01","netmask":"24","description":"Proxmox node 1","shutdown_command":"sudo /sbin/shutdown -h now","shutdown_timeout":120,"wake_after_restore":true},{"name":"pve-02","ip":"192.168.1.11","mac":"AA:BB:CC:DD:EE:02","netmask":"24","description":"Proxmox node 2","shutdown_command":"sudo /sbin/shutdown -h now","shutdown_timeout":120,"wake_after_restore":true}]'

# Battery charge must reach this level after AC returns before restore-watcher wakes hosts.
# Prevents waking into an immediate second shutdown if power is unstable.
RESTORE_WAKEUP_BATTERY_THRESHOLD=60
RESTORE_POLL_INTERVAL=30

# FINALDELAY for the NanoPi's own nut-monitor client (passed to setup-nut-client.sh).
# The NanoPi must shut down after all other NUT clients but before the UPS cuts power.
# Rule of thumb: NUT_FINAL_DELAY > (other clients' FINALDELAY)
#                KILLPOWER_DELAY < NUT_FINAL_DELAY
#                UPS cuts power at: FSD + KILLPOWER_DELAY + NUT_UPS_OFF_DELAY
NUT_FINAL_DELAY=120

# Seconds after FSD is detected before restore-watcher sends driver.killpower.
# Must be less than NUT_FINAL_DELAY so killpower fires while restore-watcher is still up.
KILLPOWER_DELAY=60

# Explicit wake target overrides. Leave blank to use UPSNAP_HOSTS_JSON MACs.
UPSNAP_DEVICE_IDS=
WAKE_MAC_ADDRESSES=

# extra variables so this can be used per nut-client
NUT_SERVER=10.0.0.2
