# source app data directory
DATA_DIR=/opt/example-app/data

# short app name used in archive names
APP_NAME=exampleapp

# backup target, use r2 or local
BACKUP_DEST_TYPE=local

# rclone remote and bucket path, used when target is r2
RCLONE_REMOTE=r2:example-backups

# local hoover directory, used when target is local
LOCAL_DEST_DIR=/mnt/backup-hoover/exampleapp

# age public key used to encrypt backups
AGE_PUBLIC_KEY=age1examplepublickeyreplacewithrealkey

# optional healthchecks url, leave empty to disable pings
HEALTHCHECKS_URL=

# r2 retention in days, used when target is r2
RETENTION_DAYS=30

# optional relative path patterns to skip, separated by spaces
EXCLUDE_PATTERNS='tmp tmp/* cache cache/* logs logs/* node_modules node_modules/*'

# install missing tools with apk or apt, use yes or no
AUTO_INSTALL_DEPS=no

# optional lock directory, leave empty for the default
LOCK_DIR=
